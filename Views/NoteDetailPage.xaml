<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudySync.ViewModels"
             x:Class="StudySync.Views.NoteDetailPage"
             x:DataType="viewModels:NoteDetailViewModel"
             Title="{Binding NoteTitle}"
             BackgroundColor="{DynamicResource Background}">

    <Grid RowDefinitions="Auto, *" Padding="16" RowSpacing="12">

        <!-- Note Info Card -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource White}"
                StrokeThickness="0"
                Padding="16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="8">
                <Label Text="{Binding NoteTitle}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource Primary}" />

                <HorizontalStackLayout Spacing="12">
                    <Label Text="{Binding CourseCode}"
                           FontSize="14"
                           TextColor="{DynamicResource Gray600}" />
                    <Label Text="•"
                           TextColor="{DynamicResource Gray600}" />
                    <Label Text="{Binding ContentType}"
                           FontSize="14"
                           TextColor="{DynamicResource Gray600}" />
                    <Label Text="•"
                           TextColor="{DynamicResource Gray600}" />
                    <Label Text="{Binding CreatedDate}"
                           FontSize="14"
                           TextColor="{DynamicResource Gray600}" />
                </HorizontalStackLayout>

                <Label Text="📝 Extracted Text"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,8,0,0" />
            </VerticalStackLayout>
        </Border>

        <!-- Scrollable Text Content -->
        <Border Grid.Row="1"
                BackgroundColor="{DynamicResource White}"
                StrokeThickness="0"
                Padding="16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <ScrollView>
                <Label Text="{Binding NoteText}"
                       FontSize="14"
                       TextColor="{DynamicResource Gray900}"
                       LineBreakMode="WordWrap" />
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>