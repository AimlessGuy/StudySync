<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudySync.Views.ResultPage"
             xmlns:viewModels="clr-namespace:StudySync.ViewModels"
             x:DataType="viewModels:ResultViewModel"
             Title="Extracted Text"
             BackgroundColor="{DynamicResource Background}">

    <!-- Grid: image+progress fixed at top, text scrolls in middle, buttons pinned at bottom -->
    <Grid RowDefinitions="Auto, *, Auto" Padding="16" RowSpacing="12">

        <!-- TOP: Image + progress indicator -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <!-- Captured Image -->
            <Border BackgroundColor="{DynamicResource Gray200}"
                    StrokeThickness="0"
                    HeightRequest="180">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Image x:Name="CapturedImage"
                       Aspect="AspectFit"
                       Margin="10" />
            </Border>

            <!-- OCR Progress (visible while processing) -->
            <VerticalStackLayout Spacing="6"
                                 IsVisible="{Binding IsProcessing}">
                <Label Text="{Binding OcrStatus}"
                       HorizontalOptions="Center"
                       FontSize="13"
                       TextColor="{DynamicResource Primary}" />
                <ProgressBar Progress="{Binding OcrProgress}"
                             ProgressColor="{DynamicResource Primary}"
                             HeightRequest="8" />
                <Label Text="{Binding OcrProgressPercent, StringFormat='{0}%'}"
                       HorizontalOptions="Center"
                       FontSize="12"
                       TextColor="{DynamicResource Gray500}" />
            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- MIDDLE: Scrollable extracted text — takes all remaining space -->
        <Border Grid.Row="1"
                BackgroundColor="{DynamicResource White}"
                StrokeThickness="0"
                Padding="16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto, *">
                <Label Grid.Row="0"
                       Text="📝 Extracted Text"
                       TextColor="{DynamicResource Primary}"
                       FontSize="18"
                       FontAttributes="Bold"
                       Margin="0,0,0,8" />

                <!-- ScrollView here is bounded by the Grid row, so it actually scrolls -->
                <ScrollView Grid.Row="1">
                    <Editor Text="{Binding ExtractedText}"
        BackgroundColor="{DynamicResource Gray100}"
        HeightRequest="350"
        FontSize="14"
        IsReadOnly="True"
        TextColor="Black" />
                    
                </ScrollView>
            </Grid>
        </Border>

        <!-- BOTTOM: Action buttons pinned at bottom -->
        <VerticalStackLayout Grid.Row="2" Spacing="8">

            <Grid ColumnDefinitions="*, *"
                  ColumnSpacing="8"
                  IsEnabled="{Binding IsTextExtracted}">
                <Button Grid.Column="0"
                        Text="💾 Save to Vault"
                        Command="{Binding SaveNoteCommand}"
                        BackgroundColor="{DynamicResource Primary}"
                        CornerRadius="8" />
                <Button Grid.Column="1"
                        Text="📤 Share"
                        Command="{Binding ShareNoteCommand}"
                        BackgroundColor="{DynamicResource Secondary}"
                        TextColor="{DynamicResource Gray900}"
                        CornerRadius="8" />
            </Grid>

            <Button Text="🔄 Process Again"
                    Command="{Binding ProcessAgainCommand}"
                    BackgroundColor="{DynamicResource Gray500}"
                    CornerRadius="8"
                    IsEnabled="{Binding IsTextExtracted}" />

        </VerticalStackLayout>

    </Grid>
</ContentPage>
